{
  "name": "twenty-zero-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:cfb": "vite --mode cfb --open /cfb.html",
    "build:cfb": "vite build --mode cfb && mv dist-cfb/cfb.html dist-cfb/index.html",
    "preview:cfb": "vite preview --mode cfb --outDir dist-cfb"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11"
  }
}
