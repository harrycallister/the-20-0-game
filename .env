# Single source of truth for the site's absolute URL.
# Used by: index.html OG/Twitter meta tags (%VITE_SITE_URL%) and src/share.js
# (share text + image footer). vite base stays './' so paths work anywhere.
#
# When you buy a custom domain, change this ONE line (no trailing slash),
# then see the commented CNAME step in .github/workflows/deploy.yml.
VITE_SITE_URL=https://go20-0.com

